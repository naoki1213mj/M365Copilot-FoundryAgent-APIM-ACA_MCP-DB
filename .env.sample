# ローカル開発用環境変数テンプレート
# .env にコピーして値を設定してください

# Azure SQL Database (az login 済みなら MI で接続)
SQL_SERVER_FQDN=sql-xxxxxxxx.database.windows.net
SQL_DATABASE_NAME=inventory_db

# Application Insights (オプション — 設定しなくてもローカル動作する)
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxx;IngestionEndpoint=https://japaneast-1.in.applicationinsights.azure.com/

# ログレベル (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Foundry Agent テスト用 (scripts/test_agent.py)
# FOUNDRY_PROJECT_ENDPOINT=https://foundry-xxx.services.ai.azure.com/api/projects/inventory-project
# AGENT_NAME=inventory-ent-pmi

# Entra ID (APIM MCP policy 用 — postprovision で自動設定)
# ENTRA_APP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
